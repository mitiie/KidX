<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" agent="5.0">
  <diagram id="diagram_class_login" name="Analysis Class Diagram Login">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">

      <root>

        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>


        <!-- Actor -->
        <mxCell id="actor_user" value="Người dùng"
        style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;strokeColor=#333333;strokeWidth=1.5;"
        parent="1" vertex="1">

          <mxGeometry x="40" y="220" width="30" height="60" as="geometry"/>

        </mxCell>


        <!-- Boundary -->
        <mxCell id="class_ui"
        value="&lt;p style=&quot;text-align:center&quot;&gt;&lt;b&gt;«Boundary»&lt;/b&gt;&lt;/p&gt;
        &lt;p style=&quot;text-align:center&quot;&gt;&lt;b&gt;GiaoDienDangNhap&lt;/b&gt;&lt;/p&gt;
        &lt;hr/&gt;
        + nhapEmail()&lt;br&gt;
        + nhapMatKhau()&lt;br&gt;
        + clickDangNhap()&lt;br&gt;
        + clickQuenMatKhau()&lt;br&gt;
        + hienThiThongBaoLoi()&lt;br&gt;
        + chuyenTrangChu()"

        style="verticalAlign=top;align=left;html=1;whiteSpace=wrap;rounded=0;fillColor=#f5f5f5;strokeColor=#b3b3b3;fontSize=12;"
        parent="1" vertex="1">

          <mxGeometry x="150" y="150" width="220" height="190" as="geometry"/>

        </mxCell>



        <!-- Control -->
        <mxCell id="class_control"

        value="&lt;p style=&quot;text-align:center&quot;&gt;&lt;b&gt;«Control»&lt;/b&gt;&lt;/p&gt;
        &lt;p style=&quot;text-align:center&quot;&gt;&lt;b&gt;HeThongDangNhap&lt;/b&gt;&lt;/p&gt;
        &lt;hr/&gt;
        + kiemTraDuLieuNhap()&lt;br&gt;
        + kiemTraEmailMatKhau()&lt;br&gt;
        + xacThucTaiKhoan()&lt;br&gt;
        + kiemTraEmailXacThuc()&lt;br&gt;
        + xuLyQuenMatKhau()&lt;br&gt;
        + hienThiKetQuaDangNhap()"


        style="verticalAlign=top;align=left;html=1;whiteSpace=wrap;rounded=0;fillColor=#f5f5f5;strokeColor=#b3b3b3;fontSize=12;"
        parent="1" vertex="1">


          <mxGeometry x="450" y="150" width="230" height="210" as="geometry"/>

        </mxCell>



        <!-- Entity -->

        <mxCell id="class_entity"

        value="&lt;p style=&quot;text-align:center&quot;&gt;&lt;b&gt;«Entity»&lt;/b&gt;&lt;/p&gt;
        &lt;p style=&quot;text-align:center&quot;&gt;&lt;b&gt;TaiKhoan&lt;/b&gt;&lt;/p&gt;
        &lt;hr/&gt;
        - idTaiKhoan&lt;br&gt;
        - email&lt;br&gt;
        - matKhau&lt;br&gt;
        - trangThaiXacMinh
        &lt;hr/&gt;
        + kiemTraMatKhau()&lt;br&gt;
        + xacNhanTaiKhoan()&lt;br&gt;
        + capNhatTrangThai()"


        style="verticalAlign=top;align=left;html=1;whiteSpace=wrap;rounded=0;fillColor=#f5f5f5;strokeColor=#b3b3b3;fontSize=12;"
        parent="1" vertex="1">


          <mxGeometry x="780" y="180" width="200" height="170" as="geometry"/>

        </mxCell>



        <!-- Connections -->


        <!-- User -> Boundary -->

        <mxCell id="conn1"
        style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#333333;"
        parent="1"
        source="actor_user"
        target="class_ui"
        edge="1">

          <mxGeometry relative="1" as="geometry"/>

        </mxCell>



        <!-- Boundary -> Control -->

        <mxCell id="conn2"
        style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#333333;"
        parent="1"
        source="class_ui"
        target="class_control"
        edge="1">

          <mxGeometry relative="1" as="geometry"/>

        </mxCell>



        <!-- Control -> Entity -->

        <mxCell id="conn3"
        style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#333333;"
        parent="1"
        source="class_control"
        target="class_entity"
        edge="1">

          <mxGeometry relative="1" as="geometry"/>

        </mxCell>


      </root>

    </mxGraphModel>

  </diagram>
</mxfile>