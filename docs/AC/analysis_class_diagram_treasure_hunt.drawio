<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" agent="5.0">
  <diagram id="diagram_class_treasure_hunt" name="Analysis Class Diagram Treasure Hunt">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="1100" math="0" shadow="0">
      <root>

        <mxCell id="0" />
        <mxCell id="1" parent="0" />


