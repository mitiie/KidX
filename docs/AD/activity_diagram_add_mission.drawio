        </mxCell>

        <!-- === CONNECTIONS === -->
        <!-- Start -> Step 1 -->
        <mxCell id="edge1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;endArrow=classic;" parent="1" source="start_node" target="step1" edge="1">
          <mxGeometry relative="1" as="geometry" />
