          <mxGeometry x="320" y="40" width="270" height="40" as="geometry" />
        </mxCell>

        <!-- === SWIMLANES BODIES === -->
        <!-- Body: Quản trị viên lane -->
        <mxCell id="body_user" value="" style="fillColor=none;strokeColor=#cccccc;strokeWidth=1;connectable=0;" parent="1" vertex="1">
          <mxGeometry x="50" y="80" width="270" height="860" as="geometry" />
        </mxCell>

        <!-- Body: Hệ thống lane -->
        <mxCell id="body_system" value="" style="fillColor=none;strokeColor=#cccccc;strokeWidth=1;connectable=0;" parent="1" vertex="1">
          <mxGeometry x="320" y="80" width="270" height="860" as="geometry" />
        </mxCell>

        <!-- === NODES === -->
        <!-- Start Node (Quản trị viên) -->
        <mxCell id="start_node" value="" style="ellipse;html=1;fillColor=#000000;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="175" y="90" width="20" height="20" as="geometry" />
        </mxCell>

        <!-- Step 1 (Quản trị viên): Trigger Thêm -->
        <mxCell id="step1" value="Quản trị viên chọn chức năng &quot;Thêm mới thử thách&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="80" y="150" width="210" height="50" as="geometry" />
        </mxCell>

        <!-- Step 2 (Hệ thống): Hiển thị giao diện -->
        <mxCell id="step2" value="Hệ thống hiển thị giao diện thêm mới thử thách" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#000000;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="350" y="230" width="210" height="50" as="geometry" />
        </mxCell>

        <!-- Step 3 (Quản trị viên): Nhập dữ liệu -->
        <mxCell id="step3" value="Quản trị viên nhập thông tin thử thách mới&#xa;(Tiêu đề, Mô tả, Mã màu, Từ khóa AI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="80" y="315" width="210" height="60" as="geometry" />
        </mxCell>

        <!-- Step 4 (Quản trị viên): Lưu -->
        <mxCell id="step4" value="Quản trị viên nhấn nút Lưu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#000000;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="80" y="415" width="210" height="50" as="geometry" />
        </mxCell>

        <!-- Step 5 (Hệ thống): Kiểm tra hợp lệ -->
        <mxCell id="step5" value="Hệ thống kiểm tra thông tin và xác nhận&#xa;tính hợp lệ của dữ liệu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#000000;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="350" y="500" width="210" height="55" as="geometry" />
        </mxCell>

        <!-- Decision 1 (Hệ thống): Dữ liệu hợp lệ? -->
        <mxCell id="decision1" value="Dữ liệu&#xa;hợp lệ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="405" y="595" width="100" height="70" as="geometry" />
        </mxCell>

        <!-- Step 6 (Hệ thống): Lưu CSDL -->
        <mxCell id="step6" value="Hệ thống nhập thông tin mới vào CSDL (Firebase)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#000000;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="350" y="710" width="210" height="55" as="geometry" />
        </mxCell>

        <!-- Step 7 (Hệ thống): Báo thành công -->
