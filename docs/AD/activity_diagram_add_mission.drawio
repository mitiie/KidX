        <!-- Step 1 -> Step 2 -->
        <mxCell id="edge2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;endArrow=classic;entryX=0.5;entryY=0;" parent="1" source="step1" target="step2" edge="1">
          <mxGeometry relative="1" as="geometry">
