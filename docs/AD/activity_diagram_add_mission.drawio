          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 7 -> End Node -->
        <mxCell id="edge10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;endArrow=classic;" parent="1" source="step7" target="end_node" edge="1">
