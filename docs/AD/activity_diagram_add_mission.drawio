        </mxCell>

        <!-- Decision 1 -> Step 6 (Có) -->
        <mxCell id="edge8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;endArrow=classic;" parent="1" source="decision1" target="step6" edge="1">
