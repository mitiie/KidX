        <!-- Decision 1 -> Step 3 (Không - Loop) -->
        <mxCell id="edge7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;endArrow=classic;entryX=0;entryY=0.5;" parent="1" source="decision1" target="step3" edge="1">
          <mxGeometry relative="1" as="geometry">
