        <mxCell id="lbl_no" value="Không" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;fontColor=#333333;" vertex="1" connectable="0" parent="edge7">
          <mxGeometry x="-0.7" relative="1" as="geometry">
            <mxPoint x="-15" y="-10" as="offset" />
