<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" agent="5.0">
  <diagram id="ad_register" name="Activity Diagram Register">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Headers -->
        <mxCell id="header_user" value="Người dùng"
        style="shape=partialRectangle;html=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=center;"
        vertex="1" parent="1">
          <mxGeometry x="50" y="40" width="350" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="header_system" value="Hệ thống"
        style="shape=partialRectangle;html=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=center;"
        vertex="1" parent="1">
          <mxGeometry x="400" y="40" width="350" height="40" as="geometry"/>
        </mxCell>


        <!-- Lanes -->
        <mxCell id="lane_user" value=""
        style="fillColor=none;strokeColor=#cccccc;"
        vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="350" height="800" as="geometry"/>
        </mxCell>

        <mxCell id="lane_system" value=""
        style="fillColor=none;strokeColor=#cccccc;"
        vertex="1" parent="1">
          <mxGeometry x="400" y="80" width="350" height="800" as="geometry"/>
        </mxCell>


        <!-- Start -->
        <mxCell id="start" value=""
        style="ellipse;fillColor=#000000;"
        vertex="1" parent="1">
          <mxGeometry x="215" y="100" width="20" height="20" as="geometry"/>
        </mxCell>


        <!-- User select -->
        <mxCell id="select_register"
        value="Người dùng chọn&#10;&quot;Đăng ký&quot;"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
        vertex="1" parent="1">
          <mxGeometry x="130" y="150" width="180" height="50" as="geometry"/>
        </mxCell>


        <!-- System show form -->
        <mxCell id="show_form"
        value="Hiển thị giao diện đăng ký&#10;(Email, Mật khẩu, Xác nhận)"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;"
        vertex="1" parent="1">
          <mxGeometry x="485" y="145" width="180" height="60" as="geometry"/>
        </mxCell>


        <!-- Input -->
        <mxCell id="input"
        value="Nhập thông tin&#10;và bấm Đăng ký"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
        vertex="1" parent="1">
          <mxGeometry x="130" y="240" width="180" height="50" as="geometry"/>
        </mxCell>


        <!-- Validate -->
        <mxCell id="validate"
        value="Kiểm tra dữ liệu&#10;và gửi email xác minh"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;"
        vertex="1" parent="1">
          <mxGeometry x="485" y="235" width="180" height="60" as="geometry"/>
        </mxCell>


        <!-- Decision -->
        <mxCell id="check"
        value="Thông tin hợp lệ?"
        style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;"
        vertex="1" parent="1">
          <mxGeometry x="520" y="340" width="120" height="80" as="geometry"/>
        </mxCell>


        <!-- Error -->
        <mxCell id="error"
        value="Hiển thị thông báo lỗi&#10;(thiếu dữ liệu, sai định dạng,&#10;email đã tồn tại)"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;"
        vertex="1" parent="1">
          <mxGeometry x="485" y="480" width="180" height="70" as="geometry"/>
        </mxCell>


        <!-- Confirm mail -->
        <mxCell id="confirm_mail"
        value="Xác nhận email&#10;qua thư gửi đến"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
        vertex="1" parent="1">
          <mxGeometry x="130" y="480" width="180" height="50" as="geometry"/>
        </mxCell>


        <!-- Success -->
        <mxCell id="success"
        value="Hiển thị thông báo&#10;tạo tài khoản thành công"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;"
        vertex="1" parent="1">
          <mxGeometry x="485" y="580" width="180" height="60" as="geometry"/>
        </mxCell>


        <!-- User confirm -->
        <mxCell id="confirm"
        value="Bấm xác nhận"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
        vertex="1" parent="1">
          <mxGeometry x="130" y="680" width="180" height="50" as="geometry"/>
        </mxCell>


        <!-- Back login -->
        <mxCell id="back_login"
        value="Chuyển về&#10;màn hình Đăng nhập"
        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;"
        vertex="1" parent="1">
          <mxGeometry x="485" y="675" width="180" height="60" as="geometry"/>
        </mxCell>


        <!-- End -->
        <mxCell id="end"
        value=""
        style="ellipse;shape=endState;fillColor=#000000;"
        vertex="1" parent="1">
          <mxGeometry x="565" y="790" width="20" height="20" as="geometry"/>
        </mxCell>



        <!-- Connections -->

        <mxCell id="e1" edge="1" parent="1" source="start" target="select_register">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="select_register" target="show_form">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="show_form" target="input">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="input" target="validate">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="validate" target="check">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>


        <!-- Invalid -->
        <mxCell id="e6" edge="1" parent="1" source="check" target="error">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="label_no" value="Không hợp lệ"
        style="edgeLabel;html=1;"
        vertex="1" connectable="0" parent="e6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>


        <!-- Valid -->
        <mxCell id="e7" edge="1" parent="1" source="check" target="confirm_mail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>


        <mxCell id="e8" edge="1" parent="1" source="confirm_mail" target="success">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>


        <mxCell id="e9" edge="1" parent="1" source="success" target="confirm">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>


        <mxCell id="e10" edge="1" parent="1" source="confirm" target="back_login">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>


        <mxCell id="e11" edge="1" parent="1" source="back_login" target="end">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>


      </root>
    </mxGraphModel>
  </diagram>
</mxfile>